<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content={get_csrf_token()} />
    <.live_title default="Jikan" suffix=" · Jikan">
      {assigns[:page_title]}
    </.live_title>
    <link phx-track-static rel="stylesheet" href={~p"/assets/css/app.css"} />
    <script defer phx-track-static type="text/javascript" src={~p"/assets/js/app.js"}>
    </script>
    <script>
      (() => {
        const setTheme = (theme) => {
          if (theme === "system") {
            localStorage.removeItem("phx:theme");
            document.documentElement.removeAttribute("data-theme");
          } else {
            localStorage.setItem("phx:theme", theme);
            document.documentElement.setAttribute("data-theme", theme);
          }
        };
        if (!document.documentElement.hasAttribute("data-theme")) {
          setTheme(localStorage.getItem("phx:theme") || "system");
        }
        window.addEventListener("storage", (e) => e.key === "phx:theme" && setTheme(e.newValue || "system"));
        
        window.addEventListener("phx:set-theme", (e) => setTheme(e.target.dataset.phxTheme));
      })();
    </script>
  </head>
  <body>
    <ul class="menu menu-horizontal w-full relative z-10 flex items-center gap-4 px-4 sm:px-6 lg:px-8">
      <div class="mr-8">
        <.link href={~p"/"} class="text-2xl font-bold text-primary">Jikan</.link>
      </div>
      <%= if @current_scope do %>
        <div class="flex-1 flex items-center gap-4">
          <li>
            <.link href={~p"/dashboard"} class="font-semibold">Dashboard</.link>
          </li>
          <li>
            <.link href={~p"/time-entries"}>Time Entries</.link>
          </li>
          <%= if Jikan.Accounts.User.manager_or_above?(@current_scope.user) do %>
            <li>
              <.link href={~p"/projects"}>Projects</.link>
            </li>
            <li>
              <.link href={~p"/clients"}>Clients</.link>
            </li>
            <%!-- TODO: Implement Reports page
            <li>
              <.link href={~p"/reports"}>Reports</.link>
            </li>
            --%>
          <% end %>
          <%!-- TODO: Implement Admin User Management
          <%= if Jikan.Accounts.User.admin?(@current_scope.user) do %>
            <li>
              <.link href={~p"/admin/users"}>User Management</.link>
            </li>
          <% end %>
          --%>
        </div>
        <div class="flex items-center gap-4">
          <li class="text-sm text-gray-600">
            {@current_scope.user.email}
            <span class="badge badge-sm ml-2">
              {@current_scope.user.role}
            </span>
          </li>
          <li>
            <.link href={~p"/users/settings"}>Settings</.link>
          </li>
          <li>
            <.link href={~p"/users/log-out"} method="delete">Log out</.link>
          </li>
        </div>
      <% else %>
        <div class="flex-1"></div>
        <div class="flex items-center gap-4">
          <li>
            <.link href={~p"/users/register"}>Register</.link>
          </li>
          <li>
            <.link href={~p"/users/log-in"}>Log in</.link>
          </li>
        </div>
      <% end %>
    </ul>
    {@inner_content}
  </body>
</html>
